# Register a new user
POST http://localhost:5000/api/auth/register
Content-Type: application/json

{
  "email": "user@example.com",
  "password": "password123",
  "name": "Test User"
}

###

# Login
POST http://localhost:5000/api/auth/login
Content-Type: application/json

{
  "email": "user@example.com",
  "password": "password123"
}

###

# Logout
POST http://localhost:5000/api/auth/logout
Authorization: Bearer YOUR_ACCESS_TOKEN

###

# Refresh token
POST http://localhost:5000/api/auth/refresh

###

# Get user profile
GET http://localhost:5000/api/users/profile/1
Authorization: Bearer YOUR_ACCESS_TOKEN

###

# Update user profile
PUT http://localhost:5000/api/users/profile/1
Authorization: Bearer YOUR_ACCESS_TOKEN
Content-Type: application/json

{
  "name": "Updated Name",
  "preferences": "Vegan",
  "allergies": "Nuts"
}

###

# Get all users (admin only)
GET http://localhost:5000/api/users?page=1&limit=10
Authorization: Bearer YOUR_ADMIN_ACCESS_TOKEN

###

# Block user (admin only)
PUT http://localhost:5000/api/users/1/block
Authorization: Bearer YOUR_ADMIN_ACCESS_TOKEN

###

# Get recipes
GET http://localhost:5000/api/recipes?page=1&limit=10

###

# Get recipe by ID
GET http://localhost:5000/api/recipes/1

###

# Get popular recipes
GET http://localhost:5000/api/recipes/popular?limit=5

###

# Create recipe (requires auth)
POST http://localhost:5000/api/recipes
Authorization: Bearer YOUR_ACCESS_TOKEN
Content-Type: application/json

{
  "title": "Sample Recipe",
  "description": "A delicious recipe",
  "cooking_time": 30,
  "calories": 500,
  "difficulty": "MEDIUM",
  "ingredients": "[{\"ingredient_id\": 1, \"amount\": 2.0, \"unit\": \"cups\"}]",
  "steps": "[{\"step_number\": 1, \"description\": \"Mix ingredients\"}]",
  "categories": "[1]",
  "tags": "[1]",
  "cuisines": "[1]"
}

###

# Update recipe
PUT http://localhost:5000/api/recipes/1
Authorization: Bearer YOUR_ACCESS_TOKEN
Content-Type: application/json

{
  "title": "Updated Recipe"
}

###

# Delete recipe
DELETE http://localhost:5000/api/recipes/1
Authorization: Bearer YOUR_ACCESS_TOKEN

###

# Add to favorites
POST http://localhost:5000/api/recipes/1/favorite
Authorization: Bearer YOUR_ACCESS_TOKEN

###

# Remove from favorites
